# Base de datos
# Nota: en docker-compose, DB_USER/DB_PASSWORD se sobreescriben por contenedor:
#   - servicio dal → vellum_app      (sin privilegios DDL)
#   - dal-migrate  → vellum_migrator (DDL; aplica migraciones Alembic)
# Los roles se aprovisionan con infra/postgres/init-roles.sh.
DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USER=vellum_app
DB_PASSWORD=
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_ENGINE=postgres

# Entorno
ENV=dev

# mTLS (obligatorio en staging y prod)
MTLS_ENABLED=false
MTLS_CERT_PATH=/certs/dal.crt
MTLS_KEY_PATH=/certs/dal.key
MTLS_CA_PATH=/certs/ca.crt

# Seguridad interna (solo dev)
INTERNAL_SERVICE_TOKEN=

# Logging
LOG_LEVEL=INFO
