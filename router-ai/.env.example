# ── Autenticación interna ─────────────────────────────────────────────────────
# API key que el backend debe enviar en el header X-API-Key
# openssl rand -base64 32
ROUTER_AI_API_KEY=BblTpOyDpOq8rOU+27VwO0/nhr3P34Cz3E0CpPKhRvY=

# ── Proveedores LLM ───────────────────────────────────────────────────────────
# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI GPT
OPENAI_API_KEY=sk-...

# DeepSeek (API compatible con OpenAI)
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Ollama (local, sin API key)
OLLAMA_BASE_URL=http://localhost:11434

# LM Studio (local, sin API key, API compatible con OpenAI)
LMSTUDIO_BASE_URL=http://localhost:1234/v1

# Google AI Studio (Gemini)
GOOGLE_API_KEY=AIza...

# ── Logging ───────────────────────────────────────────────────────────────────
# Nivel de log: DEBUG | INFO | WARNING  (default: INFO)
LOG_LEVEL=INFO
# Directorio para logs persistentes (montar como volumen Docker)
LOG_DIR=/logs

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Ruta al archivo YAML de rate limits (montar como volumen Docker)
RATE_LIMITS_CONFIG=config/rate_limits.yaml
